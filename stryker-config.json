{
  "stryker-config": {
    "project": "src/CashChangerSimulator.Core/CashChangerSimulator.Core.csproj",
    "test-projects": [
      "test/CashChangerSimulator.Tests.csproj"
    ],
    "mutate": [
      "Models/*.cs"
    ],
    "reporters": [
      "progress",
      "html"
    ],
    "concurrency": 4,
    "test-runner": "mtp",
    "coverage-analysis": "off",
    "test-case-filter": "InventoryTests|DenominationKeyTests",
    "ignore-methods": [
      "Console.WriteLine",
      "Log*",
      "ZLog*",
      "MemoryPackSerializer.*"
    ],
    "ignore-mutations": [
      "String",
      "StringMethod"
    ]
  }
}
