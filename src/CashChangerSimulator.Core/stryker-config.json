{
  "stryker-config": {
    "project-info": {
      "name": "CashChangerSimulator.Core"
    },
    "mutate": [
      "Models/Inventory.cs",
      "Models/DenominationKey.cs"
    ],
    "test-case-filter": "FullyQualifiedName~InventoryTests|FullyQualifiedName~DenominationKeyTests",
    "reporters": [
      "progress",
      "html"
    ],
    "concurrency": 6,
    "test-runner": "mtp",
    "coverage-analysis": "perTest",
    "additional-timeout": 15000,
    "break-on-initial-test-failure": true,
    "test-projects": [
      "../../test/CashChangerSimulator.Tests.csproj"
    ],
    "verbosity": "info"
  }
}
