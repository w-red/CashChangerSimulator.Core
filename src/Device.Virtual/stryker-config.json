{
  "stryker-config": {
    "project": "CashChangerSimulator.Device.Virtual.csproj",
    "test-projects": [
      "../../test/CashChangerSimulator.Tests.csproj"
    ],
    "mutate": [
      "DepositController.cs",
      "DispenseController.cs"
    ],
    "reporters": [
      "html",
      "json",
      "progress",
      "cleartext"
    ],
    "test-runner": "mtp",
    "coverage-analysis": "off",
    "test-case-filter": "FullyQualifiedName~ControllerMutationTests",
    "concurrency": 6,
    "additional-timeout": 30000,
    "verbosity": "info",
    "ignore-mutations": [
      "linq.Skip",
      "linq.Take",
      "String"
    ]
  }
}
