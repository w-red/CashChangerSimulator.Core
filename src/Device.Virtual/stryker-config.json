{
  "stryker-config": {
    "project-info": {
      "name": "CashChangerSimulator.Device.Virtual"
    },
    "mutate": [
      "DispenseController.cs",
      "DepositController.cs",
      "DiagnosticController.cs"
    ],
    "test-case-filter": "FullyQualifiedName~DispenseController | FullyQualifiedName~DepositController | FullyQualifiedName~DiagnosticController | FullyQualifiedName~DispenseAsync | FullyQualifiedName~DepositSequence",
    "reporters": [
      "progress",
      "html"
    ],
    "concurrency": 6,
    "test-runner": "mtp",
    "coverage-analysis": "perTest",
    "additional-timeout": 30000,
    "break-on-initial-test-failure": true,
    "ignore-methods": [
      "ZLogTrace",
      "ZLogDebug",
      "ZLogInformation",
      "ZLogWarning",
      "ZLogError",
      "ZLogCritical"
    ],
    "test-projects": [
      "../../test/CashChangerSimulator.Tests.csproj"
    ],
    "verbosity": "info"
  }
}
